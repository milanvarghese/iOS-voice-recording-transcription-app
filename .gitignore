# --- Secrets (NEVER commit) ---
# Config.swift holds the Supabase URL + anon key. The repo ships Config.swift.example;
# each contributor copies it to Config.swift and fills in their own values.
TranscriptionAPPMVP/TranscriptionAPPMVP/Config.swift

