<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Pre-declares that the app does not use non-exempt encryption.
	     We only ride on Apple's built-in HTTPS via URLSession; no proprietary
	     crypto, no OpenSSL, no libsodium, etc. Setting this here means Apple
	     stops prompting "Missing Compliance" on every TestFlight upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
